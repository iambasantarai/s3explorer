{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "target": "ES2022",
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "lib": ["ES2022"]
  },
  "include": ["src/**/*"],
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
